<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Login</title>
  <link rel="stylesheet" href="/css/styles.css">

</head>
<body class="<%= tema %>">

  <h1>Login</h1>

  <p>Accede a tu espacio personal de supra conciencia.</p>


  <% if (error) { %>
    <p><%= error %></p>
  <% } %>

  <form action="/login" method="POST">
    <label>
      Email:
      <input type="email" name="email">
    </label><br><br>

    <button type="submit">Entrar</button>
  </form>
<footer>
  <p>🌿 Sueños Valenti · Espacio de conexión y bienestar</p>
</footer>

</body>
</html>
